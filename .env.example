# Outreach — environment template
# Copy to a real secrets file (e.g. secrets/*.env, which is gitignored) and fill in.
# NEVER commit real values. All keys below are intentionally empty.

# ── Sourcing ─────────────────────────────────────────────────────────────────
APIFY_TOKEN=                      # primary: Apify Google Maps actor
GOOGLE_PLACES_API_KEY=            # fallback: Google Places

# ── Email discovery / enrichment ────────────────────────────────────────────
HUNTER_API_KEY=                   # Hunter domain email search
APOLLO_API_KEY=                   # optional: Apollo enrichment (--enrich only)

# ── LLM ──────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=                 # analysis + personalization

# ── Sending: provider + master gates ─────────────────────────────────────────
SEND_PROVIDER=instantly           # instantly | gmail
PIPELINE_SENDING_ENABLED=0        # 1 = live sending ON (default 0 = hold at 'queued')
PIPELINE_DAILY_SEND_CAP=30        # per-day send ceiling

# ── Sending: Instantly ────────────────────────────────────────────────────────
INSTANTLY_API_KEY=
# Per-sequence campaign routing. Suffix = sequence_key uppercased, non-alnum -> _
INSTANTLY_CAMPAIGN_ID_RESTAURANT_DEFAULT=
INSTANTLY_CAMPAIGN_ID_PHARMACY_DEFAULT=
INSTANTLY_CAMPAIGN_ID_DEALERSHIP_DEFAULT=
INSTANTLY_CAMPAIGN_ID_GENERAL_STANDARD=
INSTANTLY_CAMPAIGN_ID=            # optional bare fallback (only if the key can access it)

# ── Sending: Gmail (OAuth) ────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=               # optional short-lived token
GMAIL_FROM=
GMAIL_REPLY_TO=

# ── Operator bot (Telegram) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                 # team chat id
TELEGRAM_ALLOWED_USER_IDS=        # comma/space-separated numeric user ids (operator allowlist)

# ── Storage (optional overrides) ──────────────────────────────────────────────
LEAD_DB=                          # path override for the SQLite lead store (per-lane)
